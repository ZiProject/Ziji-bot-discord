{
	"name": "ziji-bot-discord",
	"version": "10.0.4",
	"description": "Ziji bot discord",
	"main": "index.js",
	"scripts": {
		"start": "cross-env NODE_ENV=production node index.js",
		"dev": "cross-env NODE_ENV=development nodemon index.js",
		"deploy": "node ./deploy.js",
		"postinstall": "npm run prisma:generate",
		"prisma:generate": "cross-env MONGO=mongodb://localhost:27017/ziji SQLITE_DATABASE_URL=file:./jsons/ziDB.sqlite prisma generate --schema prisma/mongo/schema.prisma && cross-env SQLITE_DATABASE_URL=file:./jsons/ziDB.sqlite prisma generate --schema prisma/sqlite/schema.prisma",
		"prisma:push:mongo": "prisma db push --schema prisma/mongo/schema.prisma",
		"prisma:push:sqlite": "cross-env SQLITE_DATABASE_URL=file:./jsons/ziDB.sqlite prisma db push --schema prisma/sqlite/schema.prisma",
		"test": "node --test --test-concurrency=1 --test-reporter=spec ./test/*.test.js",
		"check": "prettier --ignore-path .gitignore --check .",
		"format": "prettier --ignore-path .gitignore --write ."
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/zijipia/Ziji-bot-discord.git"
	},
	"keywords": [
		"ziji",
		"ziji-bot-discord",
		"zibot"
	],
	"author": "Ziji",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/zijipia/Ziji-bot-discord/issues"
	},
	"homepage": "https://github.com/zijipia/Ziji-bot-discord#readme",
	"dependencies": {
		"@google/generative-ai": "^0.24.0",
		"@iamtraction/google-translate": "^2.0.1",
		"@ngrok/ngrok": "^1.7.0",
		"@prisma/client": "^6.19.3",
		"@zibot/db": "^0.0.3",
		"@zibot/ziencryptor": "^0.0.1",
		"@ziplayer/extension": "^0.3.3",
		"@ziplayer/infinity": "^0.0.3",
		"@ziplayer/plugin": "^0.3.4",
		"@ziplayer/ytexecplug": "^0.0.4",
		"axios": "^1.13.5",
		"axios-cookiejar-support": "^7.0.0",
		"canvacord": "^6.0.2",
		"canvacord-gif": "^1.0.1",
		"chalk": "^4.1.2",
		"cloudflared": "^0.7.1",
		"cors": "^2.8.5",
		"cross-env": "^10.1.0",
		"discord-gamecord": "^4.4.2",
		"discord-giveaways": "^6.0.1",
		"discord.js": "^14.26.4",
		"dotenv": "^17.0.0",
		"express": "^5.1.0",
		"ffmpeg-static": "^5.2.0",
		"http": "^0.0.1-security",
		"jsonwebtoken": "^9.0.3",
		"makeitaquote": "^8.1.1",
		"mediaplex": "^1.0.0",
		"mongoose": "^9.0.1",
		"node-cron": "^4.4.1",
		"opusscript": "^0.0.8",
		"prism-media": "^1.3.5",
		"prisma": "^7.8.0",
		"readline": "^1.3.0",
		"sharp": "^0.35.1",
		"simple-git": "^3.27.0",
		"table": "^6.8.2",
		"tough-cookie": "^6.0.0",
		"txtgen": "^3.0.7",
		"winston": "^3.17.0",
		"ws": "^8.18.0",
		"zihooks": "^2.0.0",
		"ziplayer": "^0.3.13"
	},
	"devDependencies": {
		"nodemon": "^3.1.14",
		"prettier": "^3.3.2"
	},
	"overrides": {
		"@iamtraction/google-translate": {
			"undici": "^6.25.0"
		},
		"discord-giveaways": {
			"serialize-javascript": "^7.0.5"
		}
	}
}
