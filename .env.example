#############################################################################################################################
# Lưu ý
# Đổi tên file .env.example thành .env
##
# Attention
# Rename file .env.example to .env
#############################################################################################################################


# Token của bot (Required)
# Your Bot Token (Required)
# https://discord.com/developers/applications

TOKEN = ""

# URI cơ sở dữ liệu mongo (Optional)
# Your Mongo database URI (Optional)
# https://www.mongodb.com/

MONGO = ""

# Xem https://openweathermap.org/api (Optional)
# View https://openweathermap.org/api (Optional)

WEATHER_API_KEY = ""

# Xem https://aistudio.google.com/apikey
# View https://aistudio.google.com/apikey

GEMINI_API_KEY = ""

#  Port API of bot
SERVER_PORT = "2003"

# Cors "http://localhost:3000","https://ziji.world" or "http://localhost:3000" or "*"
CORS = "*"

# Disable auto update
DISABLE_UPDATE = "false"

# ngrok
# https://ngrok.com/

NGROK_AUTHTOKEN = "" #ngrok token -> ngrok domain in console log

CloudflaredToken = "" #Cloudflare tunnel token https://developers.cloudflare.com/cloudflare-one/networks/connectors/cloudflare-tunnel/private-net/cloudflared/
OCR_API_KEY="" #https://ocr.space/ocrapi

//web dashboard
DASHBOARD_URL = "https://bot.ziji.best/" #https://bot.ziji.best/ or http://localhost:3000/ (Optional, for web dashboard)
DISCORD_CLIENT_SECRET="" #https://discord.com/developers/applications -> Your Application -> OAuth2 -> Client Secret
API_URL = "https://api.ziji.best" #https://api.ziji.world or http://localhost:4012/ (Optional, for web dashboard)